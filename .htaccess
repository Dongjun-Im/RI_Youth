# InfinityFree — HTTPS 강제 리다이렉트 (.app TLD 는 HTTPS 필수)
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 디렉토리 목록 노출 금지
Options -Indexes

# 민감한 파일 직접 접근 차단
<FilesMatch "\.(sql|log|md|gitignore|gitkeep)$">
    Require all denied
</FilesMatch>

# 업로드 폴더에서 PHP 실행 방지 (보안)
<Directory "uploads">
    <FilesMatch "\.(php|phtml|phar)$">
        Require all denied
    </FilesMatch>
</Directory>
